{
  "rewrites": [
    {
      "source": "/api/og/:groupName",
      "destination": "/api/og/[groupName]"
    },
    {
      "source": "/([^?]*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "^(facebookexternalhit|Facebot|Twitterbot|Slackbot(?:-LinkExpanding)?|Discordbot|TelegramBot|WhatsApp|LinkedInBot|SkypeUriPreview|Pinterest(?:bot|/)|redditbot|vkShare|Tumblr|BitlyBot).*$"
        }
      ],
      "destination": "/api/og/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
