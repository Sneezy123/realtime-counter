{
  "rewrites": [
    {
      "source": "/api/og/:groupName",
      "destination": "/api/og/[groupName]"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(discord-bot|facebookexternalhit|linkedinbot|naver-blueno|slacklinkexpandingbot|snapurlpreviewbot|twitterbot)"
        }
      ],
      "destination": "/api/og/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
